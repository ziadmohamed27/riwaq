# ─────────────────────────────────────────────────────────────
# Next.js app (local / preview / production)
# انسخ هذا الملف إلى .env.local أثناء التطوير المحلي
# ─────────────────────────────────────────────────────────────

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# للاستخدامات الخلفية فقط داخل السيرفر / server actions / API routes
SUPABASE_SERVICE_ROLE_KEY=

# اختياري داخل تطبيق Next.js إذا احتجته لاحقًا في canonical URLs أو metadata
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────
# Supabase Edge Functions secrets
# لا توضع في .env.local، بل داخل Supabase secrets
# ─────────────────────────────────────────────────────────────
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# BREVO_API_KEY=
# APP_URL=https://your-domain.com

# ملاحظات:
# - لا تضع SUPABASE_SERVICE_ROLE_KEY داخل أي كود client-side
# - APP_URL يُستخدم في الروابط المرسلة في الإيميلات والإشعارات
# - ارجع إلى ENVIRONMENT_REFERENCE.md لمعرفة مكان كل متغير بالتفصيل
